{# Stat Card Component #}
{% macro stat_card(label, value_id, icon, col_size = 'col-md-3') %}
    <div class="{{ col_size }}">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted-custom mb-1">{{ label }}</p>
                        <h2 class="stat-value mb-0" id="{{ value_id }}">0</h2>
                    </div>
                    <div class="stat-icon">
                        <i class="bi {{ icon }}"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endmacro %}
