{% extends 'base.html.twig' %}

{% block title %}My Orders - Restaurant Management{% endblock %}

{% block body %}
<div class="container-fluid fade-in">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="text-yellow mb-3">
                <i class="bi bi-cart-check me-2"></i>My Orders
            </h1>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Order History</h5>
                </div>
                <div class="card-body">
                    <div id="ordersList" class="text-center py-4 animate-stagger">
                        <div class="spinner-border spinner-border-yellow" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
async function loadOrders() {
    const getTokenFunc = window.getToken || (typeof getToken === 'function' ? getToken : null);
    const apiRequestFunc = window.apiRequest || (typeof apiRequest === 'function' ? apiRequest : null);
    
    if (!getTokenFunc || !apiRequestFunc) {
        setTimeout(loadOrders, 50);
        return;
    }
    
    const token = getTokenFunc();
    if (!token) {
        window.location.href = '{{ path('app_login') }}';
        return;
    }

    try {
        const response = await apiRequestFunc('/api/orders', { method: 'GET' });
        if (response && response.ok) {
            const orders = await response.json();
            displayOrders(orders);
        } else {
            const error = await response.json();
            document.getElementById('ordersList').innerHTML = `<p class="text-danger">Error: ${error.error || 'Failed to load orders'}</p>`;
        }
    } catch (error) {
        console.error('Error loading orders:', error);
        document.getElementById('ordersList').innerHTML = '<p class="text-danger">Error loading orders. Please try again.</p>';
    }
}

function displayOrders(orders) {
    const ordersList = document.getElementById('ordersList');
    
    if (!orders || orders.length === 0) {
        ordersList.innerHTML = `
            <p class="text-muted-custom">
                <i class="bi bi-inbox me-2"></i>No orders yet. 
                <a href="{{ path('app_products') }}" class="text-yellow">Start ordering!</a>
            </p>
        `;
        return;
    }

    ordersList.innerHTML = orders.map((order, index) => `
        <div class="card mb-3 hover-lift" data-aos="fade-up" data-aos-delay="${index * 100}">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-3">
                        <h6 class="mb-1">Order #${order.id}</h6>
                        <small class="text-muted-custom">${order.order_date}</small>
                    </div>
                    <div class="col-md-3">
                        <span class="badge badge-yellow">${order.status}</span>
                    </div>
                    <div class="col-md-3">
                        <strong class="text-yellow">$${order.total_price}</strong>
                    </div>
                    <div class="col-md-3 text-end">
                        <button class="btn btn-sm btn-yellow-outline" onclick="viewOrderDetails(${order.id})">
                            <i class="bi bi-eye me-1"></i>Details
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `).join('');
}

function viewOrderDetails(orderId) {
    alert('Order details for order #' + orderId + ' coming soon!');
}

document.addEventListener('DOMContentLoaded', loadOrders);
</script>
{% endblock %}
