<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Restaurant Management{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🍽️</text></svg>">
    
    {# Bootstrap 5 CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    {# Bootstrap Icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    
    {# Custom Dark Theme CSS #}
    
</head>
    <body class="bg-dark text-light" data-turbo="false">
    {% block navbar %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-yellow">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-yellow" href="{{ path('app_home') }}">
                <i class="bi bi-cup-hot-fill me-2"></i>Restaurant Pro
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto" id="navItems">
                    <li class="nav-item" id="navDashboard" style="display: none;">
                        <a class="nav-link" href="{{ path('app_dashboard_customer') }}">
                            <i class="bi bi-house-door me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown" id="navAdmin" style="display: none;">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-speedometer2 me-1"></i>Admin
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark">
                            <li><a class="dropdown-item" href="{{ path('app_dashboard_admin') }}" data-turbo="false"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('app_admin_products') }}" data-turbo="false"><i class="bi bi-menu-button-wide me-2"></i>Manage Products</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_admin_categories') }}" data-turbo="false"><i class="bi bi-tags me-2"></i>Manage Categories</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_admin_orders') }}" data-turbo="false"><i class="bi bi-cart me-2"></i>Manage Orders</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_admin_users') }}" data-turbo="false"><i class="bi bi-people me-2"></i>Manage Users</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#" onclick="logout(); return false;" data-turbo="false"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_products') }}">
                            <i class="bi bi-menu-button-wide me-1"></i>Menu
                        </a>
                    </li>
                    <li class="nav-item" id="navOrders" style="display: none;">
                        <a class="nav-link" href="{{ path('app_orders') }}">
                            <i class="bi bi-cart me-1"></i>My Orders
                        </a>
                    </li>
                    <li class="nav-item dropdown" id="navUserDropdown" style="display: none;">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i><span id="navUserName">User</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark">
                            <li><a class="dropdown-item" href="{{ path('app_dashboard_profile') }}"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#" onclick="logout(); return false;"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </li>
                    <li class="nav-item" id="navLogin">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </a>
                    </li>
                    <li class="nav-item" id="navRegister">
                        <a class="nav-link" href="{{ path('app_register') }}">
                            <i class="bi bi-person-plus me-1"></i>Register
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    {% endblock %}

    {# Flash Messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show m-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Main Content #}
    <main class="container-fluid py-4">
        {% block body %}{% endblock %}
    </main>

    {# Toasts #}
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 11000;">
        <div id="appToast" class="toast text-bg-dark border border-secondary" role="alert" aria-live="polite" aria-atomic="true">
            <div class="toast-header bg-black text-light border-bottom border-secondary">
                <i class="bi bi-info-circle text-yellow me-2"></i>
                <strong class="me-auto" id="appToastTitle">Notice</strong>
                <small class="text-muted-custom" id="appToastMeta">just now</small>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="appToastBody">...</div>
        </div>
    </div>

    {# Footer #}
    {% block footer %}
    <footer class="bg-black text-center text-muted py-3 mt-5 border-top border-yellow">
        <div class="container">
            <p class="mb-0">&copy; {{ 'now'|date('Y') }} Restaurant Pro. Built for smooth service.</p>
        </div>
    </footer>
    {% endblock %}

    {# Bootstrap JS Bundle #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    
    {# AOS (Animate On Scroll) Library for advanced animations #}
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 800,
            easing: 'ease-in-out',
            once: true,
            offset: 100
        });
    </script>
    
    {# Custom JavaScript - Use importmap for ES modules #}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
        <script>
            // Cookie helper functions
            function setCookie(name, value, days) {
                const expires = new Date();
                expires.setTime(expires.getTime() + (days * 24 * 60 * 60 * 1000));
                document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + expires.toUTCString() + ';path=/;SameSite=Lax';
            }

            function getCookie(name) {
                const nameEQ = name + '=';
                const ca = document.cookie.split(';');
                for (let i = 0; i < ca.length; i++) {
                    let c = ca[i];
                    while (c.charAt(0) === ' ') c = c.substring(1, c.length);
                    if (c.indexOf(nameEQ) === 0) {
                        return decodeURIComponent(c.substring(nameEQ.length, c.length));
                    }
                }
                return null;
            }

            function deleteCookie(name) {
                document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 UTC;path=/;';
            }

            // Store JWT token in cookie (expires in 7 days, or match JWT expiration)
            function setToken(token) {
                // Decode token to get expiration, or default to 7 days
                let days = 7;
                try {
                    const payload = JSON.parse(atob(token.split('.')[1]));
                    if (payload.exp) {
                        const expDate = new Date(payload.exp * 1000);
                        const now = new Date();
                        const diffMs = expDate - now;
                        const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
                        if (diffDays > 0) {
                            days = diffDays;
                        }
                    }
                } catch (e) {
                    // If decode fails, use default 7 days
                }
                setCookie('jwt_token', token, days);
            }

            // Get JWT token from cookie
            function getToken() {
                return getCookie('jwt_token');
            }

            // Remove JWT token
            function removeToken() {
                deleteCookie('jwt_token');
            }

            // Logout function
            function logout() {
                // Use local or window function
                const removeTokenFunc = removeToken || (window.removeToken ? window.removeToken : removeToken);
                removeTokenFunc();
                if (window.updateNavbar) window.updateNavbar();
                if (window.showToast) window.showToast('Signed out', 'See you soon.', 'success');
                setTimeout(() => { window.location.href = '{{ path('app_login') }}'; }, 300);
            }

            // API request helper with JWT token
            async function apiRequest(url, options = {}) {
                const token = getToken();
                const headers = {
                    'Content-Type': 'application/json',
                    ...options.headers
                };
                
                if (token) {
                    headers['Authorization'] = `Bearer ${token}`;
                }

                const response = await fetch(url, {
                    ...options,
                    headers
                });

                if (response.status === 401) {
                    // Token expired or invalid
                    removeToken();
                    window.location.href = '{{ path('app_login') }}';
                    return null;
                }

                return response;
            }

            // Helper function to decode JWT (fallback if app.js hasn't loaded)
            function decodeJWTLocal(token) {
                try {
                    const base64Url = token.split('.')[1];
                    const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join(''));
                    return JSON.parse(jsonPayload);
                } catch (e) {
                    return null;
                }
            }

            // Update navbar based on JWT token (make it global so it can be called from anywhere)
            window.updateNavbar = function() {
                // Always use local functions (they're always available)
                // window functions from app.js are optional enhancements
                const getTokenFunc = typeof getToken === 'function' ? getToken : (window.getToken || function() { return null; });
                const decodeJWTFunc = typeof decodeJWTLocal === 'function' ? decodeJWTLocal : (window.decodeJWT || decodeJWTLocal);
                
                // Ensure we have at least one way to get token and decode it
                if (!getTokenFunc || !decodeJWTFunc) {
                    console.warn('updateNavbar: Functions not available, retrying...');
                    // Retry after DOM is definitely ready
                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', () => {
                            setTimeout(() => window.updateNavbar && window.updateNavbar(), 50);
                        });
                    } else {
                        setTimeout(() => window.updateNavbar && window.updateNavbar(), 100);
                    }
                    return;
                }
                
                const token = getTokenFunc();
                
                // Debug: Check if token exists (remove in production)
                if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
                    console.log('updateNavbar: Token exists?', !!token, token ? 'Yes' : 'No');
                }
                
                const navDashboard = document.getElementById('navDashboard');
                const navAdmin = document.getElementById('navAdmin');
                const navUserDropdown = document.getElementById('navUserDropdown');
                const navLogin = document.getElementById('navLogin');
                const navRegister = document.getElementById('navRegister');
                const navUserName = document.getElementById('navUserName');
                const navOrders = document.getElementById('navOrders');

                if (token) {
                    try {
                        const decoded = decodeJWTFunc(token);
                        if (decoded && decoded.roles) {
                            const isAdmin = decoded.roles.includes('ROLE_ADMIN');
                            const isCustomer = decoded.roles.includes('ROLE_CUSTOMER');
                            
                            // User is authenticated - show authenticated items
                            if (navDashboard) {
                                navDashboard.classList.remove('d-none');
                                navDashboard.style.display = '';
                            }
                            
                            // Hide login/register for all authenticated users
                            if (navLogin) {
                                navLogin.classList.add('d-none');
                                navLogin.style.display = 'none';
                            }
                            if (navRegister) {
                                navRegister.classList.add('d-none');
                                navRegister.style.display = 'none';
                            }

                            // Show Admin dropdown ONLY for admins
                            if (navAdmin) {
                                if (isAdmin) {
                                    navAdmin.classList.remove('d-none');
                                    navAdmin.style.display = '';
                                } else {
                                    navAdmin.classList.add('d-none');
                                    navAdmin.style.display = 'none';
                                }
                            }

                            // Show User dropdown ONLY for customers (NOT admins)
                            if (navUserDropdown) {
                                if (isCustomer && !isAdmin) {
                                    navUserDropdown.classList.remove('d-none');
                                    navUserDropdown.style.display = '';
                                    if (navUserName) {
                                        navUserName.textContent = decoded.name || 'User';
                                    }
                                } else {
                                    // Hide user dropdown for admins
                                    navUserDropdown.classList.add('d-none');
                                    navUserDropdown.style.display = 'none';
                                }
                            }

                            // Show orders link ONLY for customers
                            if (navOrders) {
                                if (isCustomer) {
                                    navOrders.classList.remove('d-none');
                                    navOrders.style.display = '';
                                } else {
                                    navOrders.classList.add('d-none');
                                    navOrders.style.display = 'none';
                                }
                            }
                            
                            return;
                        }
                    } catch (e) {
                        console.error('Error decoding token:', e);
                    }
                }
                
                // No token or invalid - show login/register, hide authenticated items
                if (navDashboard) {
                    navDashboard.classList.add('d-none');
                    navDashboard.style.display = 'none';
                }
                if (navAdmin) {
                    navAdmin.classList.add('d-none');
                    navAdmin.style.display = 'none';
                }
                if (navUserDropdown) {
                    navUserDropdown.classList.add('d-none');
                    navUserDropdown.style.display = 'none';
                }
                if (navOrders) {
                    navOrders.classList.add('d-none');
                    navOrders.style.display = 'none';
                }
                if (navLogin) {
                    navLogin.classList.remove('d-none');
                    navLogin.style.display = '';
                }
                if (navRegister) {
                    navRegister.classList.remove('d-none');
                    navRegister.style.display = '';
                }
            };

            // Initialize navbar - ensure it runs reliably on every page load
            function initializeNavbar() {
                // Wait for DOM elements to exist
                const navDashboard = document.getElementById('navDashboard');
                if (!navDashboard) {
                    // DOM not ready yet, retry
                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', initializeNavbar);
                    } else {
                        setTimeout(initializeNavbar, 50);
                    }
                    return;
                }
                
                // DOM is ready, ensure updateNavbar function exists and call it
                if (typeof window.updateNavbar === 'function') {
                    window.updateNavbar();
                } else {
                    // updateNavbar not defined yet, wait a bit
                    setTimeout(initializeNavbar, 50);
                }
            }
            
            // Run initialization when DOM is ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    // Call immediately
                    initializeNavbar();
                    // Also call after small delay to handle async issues
                    setTimeout(initializeNavbar, 100);
                });
            } else {
                // DOM already loaded - call immediately and after delay
                initializeNavbar();
                setTimeout(initializeNavbar, 100);
            }
            
            // Also update navbar when window fully loads (as backup)
            window.addEventListener('load', function() {
                if (typeof window.updateNavbar === 'function') {
                    window.updateNavbar();
                }
            });
            
            // Update navbar whenever navigation occurs (hashchange, popstate)
            window.addEventListener('hashchange', function() {
                if (typeof window.updateNavbar === 'function') {
                    window.updateNavbar();
                }
            });
            
            window.addEventListener('popstate', function() {
                if (typeof window.updateNavbar === 'function') {
                    window.updateNavbar();
                }
            });
            
            // Ensure admin dropdown links work correctly
            document.addEventListener('DOMContentLoaded', function() {
                // Get all admin dropdown links and ensure they navigate properly
                const adminDropdownLinks = document.querySelectorAll('#navAdmin .dropdown-item[href]');
                adminDropdownLinks.forEach(link => {
                    // Ensure data-turbo="false" is set
                    link.setAttribute('data-turbo', 'false');
                    
                    // Add explicit click handler to ensure navigation works
                    link.addEventListener('click', function(e) {
                        const href = this.getAttribute('href');
                        if (href && href !== '#' && href !== 'javascript:void(0)') {
                            // Allow normal navigation - don't prevent default
                            // Ensure Turbo is disabled
                            this.setAttribute('data-turbo', 'false');
                            // If still not working, force navigation
                            if (e.defaultPrevented || e.isDefaultPrevented()) {
                                window.location.href = href;
                            }
                        }
                    }, true); // Use capture phase to ensure it runs before other handlers
                });
                
                // Also handle User dropdown links
                const userDropdownLinks = document.querySelectorAll('#navUserDropdown .dropdown-item[href]');
                userDropdownLinks.forEach(link => {
                    link.setAttribute('data-turbo', 'false');
                });
            });

            // Global UI helpers
            window.formatMoney = function(amount, currency = 'USD') {
                const n = Number(amount);
                if (!Number.isFinite(n)) return String(amount ?? '');
                try {
                    return new Intl.NumberFormat(undefined, { style: 'currency', currency }).format(n);
                } catch (e) {
                    return '$' + n.toFixed(2);
                }
            };

            window.formatDateTime = function(value) {
                if (!value) return '-';
                const d = (value instanceof Date) ? value : new Date(value);
                if (Number.isNaN(d.getTime())) return String(value);
                return d.toLocaleString(undefined, { year: 'numeric', month: 'short', day: '2-digit', hour: '2-digit', minute: '2-digit' });
            };

            window.showToast = function(title, message, variant = 'info') {
                const toastEl = document.getElementById('appToast');
                const titleEl = document.getElementById('appToastTitle');
                const bodyEl = document.getElementById('appToastBody');
                const metaEl = document.getElementById('appToastMeta');
                if (!toastEl || !titleEl || !bodyEl) return;

                titleEl.textContent = title || 'Notice';
                bodyEl.textContent = message || '';
                if (metaEl) metaEl.textContent = 'just now';

                toastEl.classList.remove('text-bg-success', 'text-bg-danger', 'text-bg-warning', 'text-bg-info');
                if (variant === 'success') toastEl.classList.add('text-bg-success');
                else if (variant === 'danger' || variant === 'error') toastEl.classList.add('text-bg-danger');
                else if (variant === 'warning') toastEl.classList.add('text-bg-warning');
                else toastEl.classList.add('text-bg-info');

                const toast = bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 2800 });
                toast.show();
            };
        </script>
    {% endblock %}
</body>
</html>
